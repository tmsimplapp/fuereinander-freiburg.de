# Zusätzliche Server-Absicherung für das Admin-Verzeichnis
# KEIN Ersatz für die PHP-Session-Prüfung – nur Defense-in-Depth

Options -Indexes
DirectoryIndex index.php

# Direktzugriff auf config/auth/helpers blockieren
<FilesMatch "^(config|auth)\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Caching für Admin-Seiten deaktivieren
<IfModule mod_headers.c>
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "no-referrer"
</IfModule>
