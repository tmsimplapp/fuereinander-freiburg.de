# Apache-Konfiguration für saubere URLs
# Projekt: Füreinander Freiburg Landingpage

# Aktiviere Rewrite-Engine
RewriteEngine On
RewriteBase /

# Erzwinge HTTPS und Non-WWW
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,NE,R=301]

# 1. Leite /index auf / um (Startseite soll immer nur / zeigen)
RewriteCond %{THE_REQUEST} ^GET\ /index(\.html)?\ HTTP
RewriteRule ^index(\.html)?$ / [R=301,L]

# 2. Entferne .html-Endungen aus der URL (301 Permanent Redirect)
RewriteCond %{THE_REQUEST} ^GET\ (.*)\.html\ HTTP
RewriteRule (.*)\.html$ /$1 [R=301,L]

# 3. Füge .html intern hinzu, wenn Datei existiert
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L,QSA]

# 2b. Entferne .php-Endungen aus der URL (301 Permanent Redirect)
RewriteCond %{THE_REQUEST} ^GET\ (.*)\.php\ HTTP
RewriteRule (.*)\.php$ /$1 [R=301,L]

# 3b. Füge .php intern hinzu, wenn Datei existiert
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L,QSA]

# 4. DirectoryIndex für Startseite
DirectoryIndex index.php

# Sicherheit: Verhindere Zugriff auf .htaccess selbst
<Files .htaccess>
Order allow,deny
Deny from all
</Files>

# 5. Komprimierung (GZIP/Deflate) aktivieren
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# 6. Browser-Caching (Expires Headers)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
</IfModule>
